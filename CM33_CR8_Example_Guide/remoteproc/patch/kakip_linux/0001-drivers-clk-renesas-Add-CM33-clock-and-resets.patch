From 2cbeebe3d4aa13f13e1541e596eb29a94df03bf4 Mon Sep 17 00:00:00 2001
From: LiangCheng Wang <zaq14760@gmail.com>
Date: Wed, 15 Apr 2026 17:48:40 +0800
Subject: [PATCH 1/6] drivers: clk: renesas: Add CM33 clock and resets

Add the CM33 module clock and reset IDs to the R9A09G057 CPG driver
and dt-bindings so remoteproc can control the core.
---
 drivers/clk/renesas/r9a09g057-cpg.c       | 9 +++++++--
 include/dt-bindings/clock/r9a09g057-cpg.h | 4 ++++
 2 files changed, 11 insertions(+), 2 deletions(-)

diff --git a/drivers/clk/renesas/r9a09g057-cpg.c b/drivers/clk/renesas/r9a09g057-cpg.c
index abcef788f..ba317337d 100644
--- a/drivers/clk/renesas/r9a09g057-cpg.c
+++ b/drivers/clk/renesas/r9a09g057-cpg.c
@@ -792,6 +792,8 @@ static struct rzg2l_mod_clk r9a09g057_mod_clks[] = {
 					0x658, 11, 0),
 	DEF_MOD("adg_spdif2_clk",	R9A09G057_ADG_SPDIF2_CLK, CLK_PLLCLN_DIV8,
 					0x658, 12, 0),
+	DEF_MOD("cm33_clk1",		R9A09G057_CM33_CLK_1, R9A09G057_MAINCLK,
+					0x604, 2, 0),
 };
 
 static struct rzg2l_reset r9a09g057_resets[] = {
@@ -920,6 +922,9 @@ static struct rzg2l_reset r9a09g057_resets[] = {
 	DEF_RST(R9A09G057_TSU1_PRESETN,			0x93C,  8),
 	DEF_RST(R9A09G057_DRP_ARESETN,			0x93C, 12),
 	DEF_RST(R9A09G057_DRPAI_ARESETN,		0x93C, 13),
+	DEF_RST(R9A09G057_CM33_RESET2,			0x904,  3),
+	DEF_RST(R9A09G057_CM33_RESET0,			0x904,  4),
+	DEF_RST(R9A09G057_CM33_RESET1,			0x904,  5),
 };
 
 static const unsigned int r9a09g057_crit_mod_clks[] __initconst = {
@@ -1270,11 +1275,11 @@ const struct rzg2l_cpg_info r9a09g057_cpg_info = {
 	/* Module Clocks */
 	.mod_clks = r9a09g057_mod_clks,
 	.num_mod_clks = ARRAY_SIZE(r9a09g057_mod_clks),
-	.num_hw_mod_clks = R9A09G057_ADG_SPDIF2_CLK + 1,
+	.num_hw_mod_clks = R9A09G057_CM33_CLK_1 + 1,
 
 	/* Resets */
 	.resets = r9a09g057_resets,
-	.num_resets = R9A09G057_RCPU_DMAC_1_ARESETN + 1, /* Last reset ID + 1 */
+	.num_resets = R9A09G057_CM33_RESET1 + 1, /* Last reset ID + 1 */
 
 	/* Clocks Monitoring */
 	.clk_mons = r9a09g057_clk_mon,
diff --git a/include/dt-bindings/clock/r9a09g057-cpg.h b/include/dt-bindings/clock/r9a09g057-cpg.h
index e6e980d2e..a26af8ee9 100644
--- a/include/dt-bindings/clock/r9a09g057-cpg.h
+++ b/include/dt-bindings/clock/r9a09g057-cpg.h
@@ -294,6 +294,7 @@
 #define R9A09G057_ADG_SPDIF0_CLK		280
 #define R9A09G057_ADG_SPDIF1_CLK		281
 #define R9A09G057_ADG_SPDIF2_CLK		282
+#define R9A09G057_CM33_CLK_1			283
 
 /* R9A09G057 Resets */
 #define R9A09G057_CA55_NCPUPORESET3		0
@@ -456,5 +457,8 @@
 #define R9A09G057_MCPU_DMAC_0_ARESETN		157
 #define R9A09G057_RCPU_DMAC_0_ARESETN		158
 #define R9A09G057_RCPU_DMAC_1_ARESETN		159
+#define R9A09G057_CM33_RESET2			160
+#define R9A09G057_CM33_RESET0			161
+#define R9A09G057_CM33_RESET1			162
 
 #endif /* __DT_BINDINGS_CLOCK_R9A09G057_CPG_H__ */
-- 
2.34.1

