From b71f6c03b0ab4b6fd84d7b971d7018889dc9359d Mon Sep 17 00:00:00 2001
From: LiangCheng Wang <zaq14760@gmail.com>
Date: Wed, 15 Apr 2026 17:49:02 +0800
Subject: [PATCH 4/6] arm64: dts: renesas: kakip-es1: Add Kakip CM33 remoteproc
 node

Expose the CPG and SYSC blocks as syscon providers and
describe the Kakip CM33 remote processor resources,
reserved memory, clocks, resets, and resource table location.
---
 arch/arm64/boot/dts/renesas/kakip-es1.dts  | 44 ++++++++++++++++++++++
 arch/arm64/boot/dts/renesas/r9a09g057.dtsi |  4 +-
 2 files changed, 46 insertions(+), 2 deletions(-)

diff --git a/arch/arm64/boot/dts/renesas/kakip-es1.dts b/arch/arm64/boot/dts/renesas/kakip-es1.dts
index d62fa4fe2..f3d294e71 100644
--- a/arch/arm64/boot/dts/renesas/kakip-es1.dts
+++ b/arch/arm64/boot/dts/renesas/kakip-es1.dts
@@ -93,6 +93,24 @@ drp_reserved: DRP-AI@D0000000 {
 			reusable;
 			reg = <0x0 0xD0000000 0x0 0x20000000>;
 		};
+
+		vdev0vring0: vdev0vring0@43000000 {
+			compatible = "shared-dma-pool";
+			reg = <0x0 0x43000000 0x0 0x50000>;
+			no-map;
+		};
+
+		vdev0vring1: vdev0vring1@43050000 {
+			compatible = "shared-dma-pool";
+			reg = <0x0 0x43050000 0x0 0x50000>;
+			no-map;
+		};
+
+		vdev0buffer: vdev0buffer@43200000 {
+			compatible = "shared-dma-pool";
+			reg = <0x0 0x43200000 0x0 0x300000>;
+			no-map;
+		};
 	};
 
 	mmngr {
@@ -657,3 +675,29 @@ &drpai0 {
     image-memory-region = <&image_buf0>;
     status = "okay";
 };
+
+&soc {
+	cm33_rproc: cm33 {
+		compatible = "renesas,rz-cm33";
+		reg = <0x0 0x08000000 0x0 0x00fffff>,
+		      <0x0 0x40010000 0x0 0x3ef0000>;
+		reg-names = "cm33_sram", "cm33_ddr";
+		memory-region = <&vdev0vring0>, <&vdev0vring1>, <&vdev0buffer>;
+		renesas,rz-cpg = <&cpg>;
+		renesas,rz-sysc = <&sysc>;
+		renesas,rz-bootaddrs = <0x08003000>, <0x18003000>;
+		renesas,rz-rsctbl = <0x42F00000>;
+		clocks = <&cpg CPG_MOD R9A09G057_CM33_CLK_1>;
+		clock-names = "cm33clk1";
+		resets = <&cpg R9A09G057_CM33_RESET2>,
+			 <&cpg R9A09G057_CM33_RESET0>,
+			 <&cpg R9A09G057_CM33_RESET1>;
+		reset-names = "cm33reset2", "cm33reset0", "cm33reset1";
+		power-domains = <&cpg>;
+		status = "okay";
+	};
+};
+
+&sysc {
+	status = "okay";
+};
diff --git a/arch/arm64/boot/dts/renesas/r9a09g057.dtsi b/arch/arm64/boot/dts/renesas/r9a09g057.dtsi
index 2006fda0b..9e6ebcebc 100644
--- a/arch/arm64/boot/dts/renesas/r9a09g057.dtsi
+++ b/arch/arm64/boot/dts/renesas/r9a09g057.dtsi
@@ -200,7 +200,7 @@ soc: soc {
 		ranges;
 
 		cpg: clock-controller@10420000 {
-			compatible = "renesas,r9a09g057-cpg";
+			compatible = "renesas,r9a09g057-cpg", "syscon";
 			reg = <0 0x10420000 0 0x10000>;
 			clocks = <&extal_clk>,
 				 <&et0_txc_tx_clk>, <&et0_rxc_rx_clk>,
@@ -216,7 +216,7 @@ cpg: clock-controller@10420000 {
 		};
 
 		sysc: system-controller@10430000 {
-			compatible = "renesas,r9a09g057-sysc";
+			compatible = "renesas,r9a09g057-sysc", "syscon";
 			reg = <0 0x10430000 0 0x10000>;
 			status = "disabled";
 		};
-- 
