From 2fcdb5e93f0e80986c80873307faeb9fbb53ca67 Mon Sep 17 00:00:00 2001
From: LiangCheng Wang <zaq14760@gmail.com>
Date: Fri, 17 Apr 2026 17:54:43 +0800
Subject: [PATCH 3/5] plat: renesas: rzv2h: add CM33 boot control

Add the CPG and SYS programming sequence required to start the CM33.
The sequence configures the MCPU vector registers, enables the CM33 clock,
powers the CM33 domain, controls reset release and checks whether the core is already running.

Also allow the required SRAM and interconnect paths while
CM33 boot support is enabled, then start CM33 from BL2 before handing off to the next image.
---
 plat/renesas/rz/soc/v2h/bl2_plat_setup.c |  22 ++++-
 plat/renesas/rz/soc/v2h/drivers/cpg.c    | 118 +++++++++++++++++++++++
 plat/renesas/rz/soc/v2h/drivers/sys.c    |  38 ++++++++
 plat/renesas/rz/soc/v2h/include/cpg.h    |   8 ++
 plat/renesas/rz/soc/v2h/include/sys.h    |   5 +
 plat/renesas/rz/soc/v2h/plat_security.c  |   4 +
 6 files changed, 192 insertions(+), 3 deletions(-)

diff --git a/plat/renesas/rz/soc/v2h/bl2_plat_setup.c b/plat/renesas/rz/soc/v2h/bl2_plat_setup.c
index 8f2b11d..c09b2d2 100644
--- a/plat/renesas/rz/soc/v2h/bl2_plat_setup.c
+++ b/plat/renesas/rz/soc/v2h/bl2_plat_setup.c
@@ -59,9 +59,11 @@ int bl2_plat_handle_pre_image_load(unsigned int image_id)
 		}
 	}
 #if PLAT_M33_BOOT_SUPPORT
-	if (image_id == BL22_IMAGE_ID &&
-	    bl2_plat_get_boot_mode() == RZ_WARM_BOOT) {
-		bl_mem_params->image_info.h.attr |= IMAGE_ATTRIB_SKIP_LOADING;
+	if (image_id == BL22_IMAGE_ID) {
+		if (sys_is_m33_core_booted() ||
+		    bl2_plat_get_boot_mode() == RZ_WARM_BOOT) {
+			bl_mem_params->image_info.h.attr |= IMAGE_ATTRIB_SKIP_LOADING;
+		}
 	}
 #endif
 
@@ -178,6 +180,20 @@ void bl2_el3_plat_arch_setup(void)
 	enable_mmu_el3(0);
 }
 
+#if PLAT_M33_BOOT_SUPPORT
+void bl2_el3_plat_prepare_exit(void)
+{
+	if (!sys_is_m33_core_booted()) {
+		bl_mem_params_node_t *bl22_mem_params;
+
+		bl22_mem_params = get_bl_mem_params_node(BL22_IMAGE_ID);
+		if (bl22_mem_params != NULL) {
+			sys_m33_core_boot_on(bl22_mem_params->ep_info.pc);
+		}
+	}
+}
+#endif
+
 void bl2_platform_setup(void)
 {
 	/* Setup TZC-400, Access Control */
diff --git a/plat/renesas/rz/soc/v2h/drivers/cpg.c b/plat/renesas/rz/soc/v2h/drivers/cpg.c
index 75134ce..0dc9c52 100644
--- a/plat/renesas/rz/soc/v2h/drivers/cpg.c
+++ b/plat/renesas/rz/soc/v2h/drivers/cpg.c
@@ -1686,6 +1686,53 @@ static CPG_SETUP_DATA cpg_reset_tbl[] = {
 
 };
 
+#if PLAT_M33_BOOT_SUPPORT
+static CPG_SETUP_DATA cpg_m33_clk_on_tbl[] = {
+	{	/* CM33 */
+		.reg =  {
+				.addr = (uintptr_t)CPG_CLKON_1,
+				.val  = 0x00040004,
+				},
+
+		.mon =  {
+				.addr = (uintptr_t)CPG_CLKMON_0,
+				.val  = 0x00040000,
+				},
+
+		.type = CPG_T_CLK
+	},
+};
+
+static CPG_SETUP_DATA cpg_m33_clkrst_tbl[] = {
+	{	/* CM33 */
+		.reg =  {
+				.addr = (uintptr_t)CPG_RST_1,
+				.val  = 0x00380008,
+				},
+
+		.mon =  {
+				.addr = (uintptr_t)CPG_RSTMON_0,
+				.val  = 0x00020000,
+				},
+
+		.type = CPG_T_CLK
+	},
+	{	/* CM33 */
+		.reg =  {
+				.addr = (uintptr_t)CPG_RST_1,
+				.val  = 0x00380038,
+				},
+
+		.mon =  {
+				.addr = (uintptr_t)CPG_RSTMON_0,
+				.val  = 0x000E0000,
+				},
+
+		.type = CPG_T_CLK
+	},
+};
+#endif
+
 static CPG_REG_SETTING cpg_static_select_tbl[] = {
 	{ (uintptr_t)CPG_CSDIV0,				0x00000000 },
 	{ (uintptr_t)CPG_CSDIV1,				0x00000000 },
@@ -1699,6 +1746,20 @@ static CPG_REG_SETTING cpg_dynamic_select_tbl[] = {
 	{ (uintptr_t)CPG_CDDIV4,				0x01110111 },
 };
 
+#if PLAT_M33_BOOT_SUPPORT
+static void cpg_ctrl_clk(CPG_SETUP_DATA const *array, uint32_t num)
+{
+	int i;
+
+	for (i = 0; i < num; i++, array++) {
+		uint32_t val = (array->reg.val & 0xFFFF) |
+			       ((array->reg.val & 0xFFFF) << 16);
+
+		mmio_write_32(array->reg.addr, val);
+	}
+}
+#endif
+
 static void cpg_ctrl_clkrst(CPG_SETUP_DATA const *array, uint32_t num)
 {
 	int i;
@@ -1821,6 +1882,10 @@ static void cpg_mstop_setup(void)
 										| CPG_BUS_4_MSTOP_XSPI
 										| CPG_BUS_4_MSTOP_SECURE_IP_P0
 										| CPG_BUS_4_MSTOP_SECURE_IP_P1
+#if PLAT_M33_BOOT_SUPPORT
+										| CPG_BUS_4_MSTOP_SRAM0
+										| CPG_BUS_4_MSTOP_SRAM1
+#endif
 										| CPG_BUS_4_MSTOP_MHU);
 
 	REMOVE_MSTOPS_W(CPG_BUS_5_MSTOP,      CPG_BUS_5_MSTOP_TSU0
@@ -1923,6 +1988,9 @@ static void cpg_mstop_setup(void)
 										| CPG_BUS_11_MSTOP_GTM6);
 
 	REMOVE_MSTOPS_W(CPG_BUS_12_MSTOP,     CPG_BUS_12_MSTOP_GTM7
+#if PLAT_M33_BOOT_SUPPORT
+										| CPG_BUS_12_MSTOP_ACPU_TO_MCPU
+#endif
 										| CPG_BUS_12_MSTOP_MCPU_TO_ACPU);
 }
 
@@ -2105,3 +2173,53 @@ void cpg_setup(void)
 	cpg_div_sel_dynamic_setup();
 	cpg_wdtrst_sel_setup();
 }
+
+#if PLAT_M33_BOOT_SUPPORT
+void cpg_m33_setup(void)
+{
+	cpg_ctrl_clkrst(cpg_m33_clkrst_tbl, ARRAY_SIZE(cpg_m33_clkrst_tbl));
+}
+
+void cpg_m33_clk_on_setup(void)
+{
+	cpg_ctrl_clk(cpg_m33_clk_on_tbl, ARRAY_SIZE(cpg_m33_clk_on_tbl));
+}
+
+void cpg_m33_pwr_domain_on_setup(void)
+{
+	uint32_t val;
+
+	mmio_write_32(CPG_LP_CM33CTL1, 0x00003100);
+	do {
+		val = mmio_read_32(CPG_LP_CM33CTL1);
+	} while ((val & 0x00100000) != 0);
+}
+
+void cpg_m33_reset(void)
+{
+	uint32_t val;
+
+	mmio_write_32(CPG_CM33_CTL, 0x00000001);
+	mmio_write_32(CPG_RST_1, 0x00380000);
+	do {
+		val = mmio_read_32(CPG_RSTMON_0);
+	} while ((val & 0x000E0000) != 0x000E0000);
+}
+
+void cpg_m33_reset_release(void)
+{
+	uint32_t val;
+
+	mmio_write_32(CPG_RST_1, 0x00380008);
+	do {
+		val = mmio_read_32(CPG_RSTMON_0);
+	} while ((val & 0x000E0000) != 0x000C0000);
+
+	mmio_write_32(CPG_RST_1, 0x00380038);
+	do {
+		val = mmio_read_32(CPG_RSTMON_0);
+	} while ((val & 0x000E0000) != 0);
+
+	mmio_write_32(CPG_CM33_CTL, 0x00000000);
+}
+#endif
diff --git a/plat/renesas/rz/soc/v2h/drivers/sys.c b/plat/renesas/rz/soc/v2h/drivers/sys.c
index b1a47b1..08a9d09 100644
--- a/plat/renesas/rz/soc/v2h/drivers/sys.c
+++ b/plat/renesas/rz/soc/v2h/drivers/sys.c
@@ -8,9 +8,20 @@
 #include <lib/mmio.h>
 #include <sys.h>
 #include <sys_regs.h>
+#if PLAT_M33_BOOT_SUPPORT
+#include <cpg.h>
+#include <cpg_regs.h>
+#endif
 #include <common/debug.h>
 #include <pwrc_board.h>
 
+#if PLAT_M33_BOOT_SUPPORT
+#define V2H_SECURE_VECTOR_ADDRESS	0x100060
+#define V2H_NON_SECURE_VECTOR_ADDRESS	0x300060
+#define V2H_SYS_MCPU_CFG2_INITSVTOR	(V2H_SECURE_VECTOR_ADDRESS << 7)
+#define V2H_SYS_MCPU_CFG3_INITSVTOR	(V2H_NON_SECURE_VECTOR_ADDRESS << 7)
+#endif
+
 bool sys_is_resume_reboot(void)
 {
 #if PLAT_SYSTEM_SUSPEND
@@ -49,3 +60,30 @@ boot_mode_t sys_get_boot_mode(void)
 
 	return boot_mode;
 }
+
+#if PLAT_M33_BOOT_SUPPORT
+void sys_mcpu_config_setup(void)
+{
+	mmio_write_32(SYS_MCPU_CFG2, V2H_SYS_MCPU_CFG2_INITSVTOR);
+	mmio_write_32(SYS_MCPU_CFG3, V2H_SYS_MCPU_CFG3_INITSVTOR);
+}
+
+void sys_m33_core_boot_on(uintptr_t vector)
+{
+	(void)vector;
+
+	sys_mcpu_config_setup();
+	cpg_m33_clk_on_setup();
+	cpg_m33_pwr_domain_on_setup();
+	cpg_m33_reset();
+	cpg_m33_reset_release();
+}
+
+bool sys_is_m33_core_booted(void)
+{
+	uint32_t clkmon = mmio_read_32(CPG_CLKMON_0) & 0x00040000;
+	uint32_t rstmon = mmio_read_32(CPG_RSTMON_0) & 0x000E0000;
+
+	return (clkmon == 0x00040000) && (rstmon == 0);
+}
+#endif
diff --git a/plat/renesas/rz/soc/v2h/include/cpg.h b/plat/renesas/rz/soc/v2h/include/cpg.h
index c2fa3ea..6eb1917 100644
--- a/plat/renesas/rz/soc/v2h/include/cpg.h
+++ b/plat/renesas/rz/soc/v2h/include/cpg.h
@@ -16,4 +16,12 @@ void cpg_ddr1_part2(void);
 void cpg_prepare_suspend(void);
 void cpg_ddr_pwrokin_off(uint8_t base);
 
+#if PLAT_M33_BOOT_SUPPORT
+void cpg_m33_setup(void);
+void cpg_m33_clk_on_setup(void);
+void cpg_m33_pwr_domain_on_setup(void);
+void cpg_m33_reset(void);
+void cpg_m33_reset_release(void);
+#endif
+
 #endif /* __CPG_H__ */
diff --git a/plat/renesas/rz/soc/v2h/include/sys.h b/plat/renesas/rz/soc/v2h/include/sys.h
index df039a2..bad6054 100644
--- a/plat/renesas/rz/soc/v2h/include/sys.h
+++ b/plat/renesas/rz/soc/v2h/include/sys.h
@@ -20,6 +20,11 @@ typedef enum {
 } boot_mode_t;
 
 boot_mode_t sys_get_boot_mode(void);
+#if PLAT_M33_BOOT_SUPPORT
+void sys_mcpu_config_setup(void);
+void sys_m33_core_boot_on(uintptr_t vector);
+bool sys_is_m33_core_booted(void);
+#endif
 bool sys_is_resume_reboot(void);
 
 #endif /* __SYS_H__ */
diff --git a/plat/renesas/rz/soc/v2h/plat_security.c b/plat/renesas/rz/soc/v2h/plat_security.c
index 70b3fcd..55fbda1 100644
--- a/plat/renesas/rz/soc/v2h/plat_security.c
+++ b/plat/renesas/rz/soc/v2h/plat_security.c
@@ -185,6 +185,10 @@ static void plat_tzc_msram_setup(void)
 	};
 
 	plat_tzc400_setup(RZV2H_TZC400_M33_BASE, &msram_tzc_regions[0]);
+#if PLAT_M33_BOOT_SUPPORT
+	plat_tzc400_setup(RZV2H_TZC400_R8_BASE, &msram_tzc_regions[0]);
+	plat_tzc400_setup(RZV2H_TZC400_A55_BASE, &msram_tzc_regions[0]);
+#endif
 }
 
 static void plat_tzc_ddr_setup(void)
